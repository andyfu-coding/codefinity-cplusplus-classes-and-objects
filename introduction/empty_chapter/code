#include <iostream>

class Transaction {
public:
    Transaction(float amount, float rate);
    float processTransaction(float feePercent, float targetRate);

    float amount;
    float rate;
    float total;
};

// Constructor implementation
Transaction::Transaction(float amount, float rate) : amount(amount), rate(rate), total(amount * rate) {
    
}

// Method implementation
float Transaction::processTransaction(float feePercent, float targetRate) {
    float fee = total * feePercent / 100;
    float totalAfterFee = total - fee;
    float finalAmount = totalAfterFee * targetRate;
    return finalAmount;
}

int main() {
    Transaction t1(100, 1.2);
    Transaction t2(50, 0.9);

    std::cout << t1.processTransaction(5, 0.8) << std::endl;   // 91.2
    std::cout << t2.processTransaction(10, 1.1) << std::endl;  // 44.55

    return 0;
}