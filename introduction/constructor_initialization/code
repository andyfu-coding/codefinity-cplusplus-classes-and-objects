#include <iostream>
#include <string>
#include <cmath>

class Location {
public:
    Location(const std::string& locationName, double xCoord, double yCoord);
    double distanceTo(const Location& other);

    std::string name;
    double x;
    double y;
};

// Constructor implementation
Location::Location(const std::string& locationName, double xCoord, double yCoord)
{
    name = locationName;
    x = xCoord;
    y = yCoord;
}

// Method implementation
double Location::distanceTo(const Location& other)
{

    double dx = x - other.x;
    double dy = y - other.y;
    
    return sqrt(dx * dx + dy * dy);
}

int main()
{
    Location home("Home", 1.0, 2.0);
    Location school("School", 4.0, 6.0);

    std::cout << "Distance from " << home.name << " to " << school.name 
              << ": " << home.distanceTo(school) << std::endl;

    return 0;
}